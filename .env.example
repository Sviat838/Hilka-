# Copy to .env.local. Values: Supabase dashboard -> Settings -> API Keys
# NOTE: .env.local is gitignored, so a fresh `git worktree` won't inherit it and the
# dev server then renders a blank page. From a worktree, copy it from the main checkout:
#   cp "$(dirname "$(git rev-parse --git-common-dir)")/.env.local" .env.local
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Deployed hilka-mcp Worker URL, shown in Settings -> Connect your AI assistant.
# Optional — the app already defaults to the deployed URL below; override only to
# point at a different/self-hosted Worker.
VITE_HILKA_MCP_URL=https://hilka-mcp.sviatik2408.workers.dev/mcp

# Product analytics (Mixpanel). OPTIONAL — with no token the app sends nothing:
# analytics degrades to a complete no-op and the SDK isn't even loaded. To enable,
# create a project at mixpanel.com and paste its Project Token (client-side, safe
# to ship). Add the same var to the Cloudflare Pages project env for production.
VITE_MIXPANEL_TOKEN=
# Optional: EU data residency / a self-hosted proxy. Leave blank for US (default).
#   EU projects -> https://api-eu.mixpanel.com
VITE_MIXPANEL_API_HOST=
# Optional: set to "true" to send events even when the browser asks Do Not Track.
# Default (blank) honours Do Not Track and stays silent for those users.
VITE_MIXPANEL_IGNORE_DNT=
